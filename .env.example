# Existing app env vars can stay here.

# --- Supabase (current auth) ---
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Option A: single connection string
AWS_RDS_DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

# Option B: individual values
AWS_RDS_HOST=
AWS_RDS_PORT=3389
AWS_RDS_DATABASE=
AWS_RDS_USER=
AWS_RDS_PASSWORD=

# TLS settings for MySQL RDS
AWS_RDS_SSL=true
AWS_RDS_SSL_VERIFY_IDENTITY=true
AWS_RDS_SSL_CA_PATH=./global-bundle.pem
# AWS_RDS_SSL_CA_PEM=

# Enable RDS-backed user-role mapping lookup in hooks.server.ts
RBAC_USE_RDS_MAPPING=false

# --- Cognito / SES (planned auth) ---
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_APP_CLIENT_SECRET=
COGNITO_ISSUER=
COGNITO_JWKS_URL=

# If using Cognito custom email sender with SES:
SES_FROM_EMAIL=
SES_FROM_NAME=NC OpStats
