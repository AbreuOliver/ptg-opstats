# Existing app env vars can stay here.

# Option A: single connection string
AWS_RDS_DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

# Option B: individual values
AWS_RDS_HOST=
AWS_RDS_PORT=3389
AWS_RDS_DATABASE=
AWS_RDS_USER=
AWS_RDS_PASSWORD=

# TLS settings for MySQL RDS
AWS_RDS_SSL=true
AWS_RDS_SSL_VERIFY_IDENTITY=true
AWS_RDS_SSL_CA_PATH=./global-bundle.pem
# AWS_RDS_SSL_CA_PEM=

# --- Custom OTP auth / SES ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=no-reply@ncopstats.org
OTP_HASH_SECRET=
APP_SESSION_SECRET=

# Phase 1 gated test endpoint only
OTP_TEST_SEND_ENABLED=false
OTP_TEST_SEND_SECRET=
OTP_TEST_ALLOWED_EMAILS=
