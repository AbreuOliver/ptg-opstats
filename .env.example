# Existing app env vars can stay here.

# Option A: single connection string
AWS_RDS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Option B: individual values
AWS_RDS_HOST=
AWS_RDS_PORT=5432
AWS_RDS_DATABASE=
AWS_RDS_USER=
AWS_RDS_PASSWORD=

# Set to true/false (default true outside dev)
AWS_RDS_SSL=true
